# GPT Bitcoin Auto-Trading System Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# AI Provider Configuration (Dual Provider Mode)
# =============================================================================

# Primary Provider: GLM-5 (Zhipu AI) - 60-70% cost savings
GLM_API_KEY=your_glm_api_key_here
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-5

# Fallback Provider: OpenAI (retained for backup)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo

# Provider Selection (optional override)
# Options: "glm", "openai", "auto" (default: auto)
AI_PROVIDER=auto

# Retry Configuration
AI_MAX_RETRIES=5
AI_INITIAL_DELAY=1.0
AI_TIMEOUT=30

# Health Check Configuration
AI_HEALTH_CHECK_INTERVAL=300
AI_FAILURE_THRESHOLD=3

# =============================================================================
# Exchange API Keys
# =============================================================================

UPBIT_ACCESS_KEY=your_upbit_access_key
UPBIT_SECRET_KEY=your_upbit_secret_key

# =============================================================================
# External Data Sources
# =============================================================================

SERPAPI_API_KEY=your_serpapi_key

# =============================================================================
# Application Settings
# =============================================================================

# Enable testnet mode for paper trading
TESTNET_MODE=false

# Trading percentage (0-100)
TRADING_PERCENTAGE=100

# Minimum order value in KRW
MIN_ORDER_VALUE=5000

# =============================================================================
# Logging Settings
# =============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=console

# =============================================================================
# Database Settings
# =============================================================================

DB_PATH=trading_decisions.sqlite
PROFILE_DB_PATH=data/profiles.db
NOTIFICATION_DB_PATH=data/notifications.db

# =============================================================================
# Scheduling
# =============================================================================

SCHEDULE_TIMES=["00:01", "08:01", "16:01"]

# =============================================================================
# Rate Limiting Settings
# =============================================================================

OPENAI_REQUESTS_PER_HOUR=60
OPENAI_TOKENS_PER_MINUTE=100000
UPBIT_REQUESTS_PER_SECOND=10
UPBIT_REQUESTS_PER_MINUTE=600

# Circuit Breaker Settings
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT=60

# API Retry Settings
API_MAX_RETRIES=3
API_BASE_DELAY=1.0
API_MAX_DELAY=60.0
